# Copy this file to .env and fill in your real key. Never commit .env to git.

# Your Firecrawl API key (from https://www.firecrawl.dev/app/api-keys)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Shared Postgres database (e.g. Neon) — the same one used by every deployment
# (local + Modal + Railway if used), so leads stay in sync everywhere.
# Looks like: postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require
DATABASE_URL=your_postgres_connection_string_here
